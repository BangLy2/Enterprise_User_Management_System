        // Password Expiry Filter
        document.getElementById('expiryFilter').addEventListener('change', function() {
            const filterValue = this.value;
            const rows = document.querySelectorAll('.expiry-row');
            const noResultsMessage = document.getElementById('noResultsMessage');
            let visibleCount = 0;

            rows.forEach(row => {
                const days = parseInt(row.getAttribute('data-days'));
                let shouldShow = false;

                switch(filterValue) {
                    case 'all':
                        shouldShow = true;
                        break;
                    case 'expired':
                        shouldShow = days < 0;
                        break;
                    case '3':
                        shouldShow = days >= 0 && days <= 3;
                        break;
                    case '7':
                        shouldShow = days >= 0 && days <= 7;
                        break;
                    case '15':
                        shouldShow = days >= 0 && days <= 15;
                        break;
                    case '30':
                        shouldShow = days >= 0 && days <= 30;
                        break;
                }

                if (shouldShow) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            document.getElementById('filteredCount').textContent = visibleCount;

            if (visibleCount === 0) {
                noResultsMessage.style.display = 'block';
                document.getElementById('passwordExpiryTable').style.display = 'none';
            } else {
                noResultsMessage.style.display = 'none';
                document.getElementById('passwordExpiryTable').style.display = 'table';
            }
        });

        // Initialize filter count on page load
        document.addEventListener('DOMContentLoaded', function() {
            const initialFilter = document.getElementById('expiryFilter').value;
            const rows = document.querySelectorAll('.expiry-row');
            let visibleCount = 0;

            rows.forEach(row => {
                const days = parseInt(row.getAttribute('data-days'));
                if (initialFilter === '15' && days >= 0 && days <= 15) {
                    visibleCount++;
                }
            });

            document.getElementById('filteredCount').textContent = visibleCount;
        });
    </script>
}