@model List<MyWeb.Controllers.DepartmentViewModel>
@using MyWeb.Helpers
@{
    ViewData["Title"] = "Department Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Department
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>All Departments</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Department Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Users Assigned</th>
                            <th>Created Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var dept in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="UserManagement"
                                           asp-action="Index"
                                           asp-route-departmentFilter="@dept.Name"
                                           class="text-decoration-none fw-bold"
                                           title="View users in @dept.Name">
                                            @dept.Name
                                        </a>
                                    </td>
                                    <td>@dept.Description</td>
                                    <td>
                                        @if (dept.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (dept.UserCount > 0)
                                        {
                                            <a asp-controller="UserManagement"
                                               asp-action="Index"
                                               asp-route-departmentFilter="@dept.Name"
                                               class="badge bg-info text-decoration-none"
                                               title="View @dept.UserCount user(s) in @dept.Name"
                                               style="cursor: pointer;">
                                                @dept.UserCount user(s)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">0 user(s)</span>
                                        }
                                    </td>
                                    <td>@dept.CreatedDate.ToEasternTimeString("MM/dd/yyyy")</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-primary">Edit</a>
                                            <form asp-action="Delete" asp-route-id="@dept.Id" method="post"
                                                  style="display: inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this department?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        @(dept.UserCount > 0 ? "disabled" : "")>
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No departments found. <a asp-action="Create">Create one now</a>.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-3">
        <strong><i class="bi bi-info-circle"></i> Tip:</strong> Click on a department name or user count to view all users in that department. You cannot delete a department that has users assigned to it.
    </div>
</div>