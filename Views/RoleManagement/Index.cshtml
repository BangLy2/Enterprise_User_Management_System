@model List<MyWeb.Controllers.RoleViewModel>
@{
    ViewData["Title"] = "Role Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Role
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5>System Roles</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Role Name</th>
                            <th>Users Assigned</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="UserManagement"
                                           asp-action="Index"
                                           asp-route-roleFilter="@role.Name"
                                           class="text-decoration-none fw-bold"
                                           title="View users with @role.Name role">
                                            @role.Name
                                        </a>
                                        @if (role.Name == "Admin" || role.Name == "User")
                                        {
                                            <span class="badge bg-warning text-dark ms-2">System Role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (role.UserCount > 0)
                                        {
                                            <a asp-controller="UserManagement"
                                               asp-action="Index"
                                               asp-route-roleFilter="@role.Name"
                                               class="badge bg-info text-decoration-none"
                                               title="View @role.UserCount user(s) with @role.Name role"
                                               style="cursor: pointer;">
                                                @role.UserCount user(s)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">0 user(s)</span>
                                        }
                                    </td>
                                    <td>
                                        @if (role.Name != "Admin" && role.Name != "User")
                                        {
                                            <form asp-action="Delete" asp-route-id="@role.Id" method="post"
                                                  style="display: inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this role?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        @(role.UserCount > 0 ? "disabled" : "")>
                                                    Delete
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Protected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center">No roles found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-3">
        <strong><i class="bi bi-info-circle"></i> Tip:</strong> Click on a role name or user count to view all users with that role. System roles (Admin, User) cannot be deleted.
    </div>
</div>