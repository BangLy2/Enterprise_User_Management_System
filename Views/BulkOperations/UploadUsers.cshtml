@model MyWeb.ViewModels.BulkUserUploadViewModel
@{
    ViewData["Title"] = "Bulk Upload Users";
}

<div class="container mt-4">
    <h1><i class="bi bi-cloud-upload"></i> Bulk Upload Users</h1>
    <p class="text-muted">Upload a CSV or Excel file to create multiple users at once</p>
    <hr />

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Upload File</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UploadUsers" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="UserFile" class="form-label"></label>
                            <input asp-for="UserFile" type="file" class="form-control" accept=".csv,.xlsx,.xls" />
                            <span asp-validation-for="UserFile" class="text-danger"></span>
                            <small class="form-text text-muted">Select a CSV or Excel file (.csv, .xlsx, .xls)</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-upload"></i> Upload Users
                            </button>
                            <div class="btn-group" role="group">
                                <a asp-action="DownloadUserTemplate" asp-route-format="csv" class="btn btn-outline-secondary">
                                    <i class="bi bi-download"></i> Download CSV Template
                                </a>
                                <a asp-action="DownloadUserTemplate" asp-route-format="excel" class="btn btn-outline-success">
                                    <i class="bi bi-file-earmark-excel"></i> Download Excel Template
                                </a>
                            </div>
                            <a asp-controller="UserManagement" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to User Management
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5>File Format Instructions</h5>
                </div>
                <div class="card-body">
                    <h6>Supported Formats:</h6>
                    <ul>
                        <li>CSV (.csv)</li>
                        <li>Excel (.xlsx, .xls)</li>
                    </ul>

                    <h6 class="mt-3">Required Columns:</h6>
                    <ul>
                        <li><strong>Username</strong> - Unique username</li>
                        <li><strong>Email</strong> - Valid email address</li>
                        <li><strong>Password</strong> - Must meet password requirements</li>
                    </ul>

                    <h6 class="mt-3">Optional Columns:</h6>
                    <ul>
                        <li><strong>FullName</strong> - User's full name</li>
                        <li><strong>Department</strong> - Department name</li>
                        <li><strong>Roles</strong> - Semicolon-separated (e.g., "User;Manager")</li>
                    </ul>

                    <div class="alert alert-warning mt-3">
                        <strong>Note:</strong> If no roles are specified, users will be assigned the "User" role by default.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}