@model MyWeb.ViewModels.BulkUploadResult
@{
    ViewData["Title"] = "Upload Results";
}

<div class="container mt-4">
    <h1><i class="bi bi-check2-circle"></i> Bulk Upload Results</h1>
    <hr />

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h6>Total Rows</h6>
                    <h2>@Model.TotalRows</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h6>Successful</h6>
                    <h2>@Model.SuccessCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h6>Failed</h6>
                    <h2>@Model.FailureCount</h2>
                </div>
            </div>
        </div>
    </div>

    @if (Model.SuccessfulUsers.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5><i class="bi bi-check-circle"></i> Successfully Created Users</h5>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    @foreach (var username in Model.SuccessfulUsers)
                    {
                        <li class="list-group-item">
                            <i class="bi bi-person-check text-success"></i> @username
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (Model.Errors.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5><i class="bi bi-exclamation-triangle"></i> Errors</h5>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    @foreach (var error in Model.Errors)
                    {
                        <li class="list-group-item list-group-item-danger">
                            <i class="bi bi-x-circle"></i> @error
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="UploadUsers" class="btn btn-primary">
            <i class="bi bi-upload"></i> Upload More Users
        </a>
        <a asp-controller="UserManagement" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-list"></i> View All Users
        </a>
    </div>
</div>